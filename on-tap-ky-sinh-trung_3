function escapeHtml(s){ return (s||'').replace(/[&<>"]/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c])); }

function persist(){
  try{
    const ans = {};
    for(const k in answers){ if(/^\d+$/.test(k)) ans[k] = answers[k]; }
    LS.set('kst_answers', JSON.stringify(ans));
    LS.set('kst_expl', JSON.stringify(explanations));
  }catch(e){}
}
function loadPersisted(){
  try{
    const a = JSON.parse(LS.get('kst_answers') || '{}'); for(const k in a) answers[k] = a[k];
    const e = JSON.parse(LS.get('kst_expl') || '{}'); Object.assign(explanations, e);
  }catch(e){}
}

const $ = id => document.getElementById(id);

/* ---------------- Build range options ---------------- */
function buildRanges(){
  const sel = $('rangeSelect');
  const total = QUESTIONS.length;
  const opt = document.createElement('option');
  opt.value = 'all'; opt.textContent = `Tất cả (${total} câu)`;
  sel.appendChild(opt);
  const CHUNK = 50;
  for(let s=0; s<total; s+=CHUNK){
    const e = Math.min(s+CHUNK, total);
    const o = document.createElement('option');
    o.value = s + '-' + e;
    o.textContent = `Câu ${s+1}–${e}`;
    sel.appendChild(o);
  }
}

/* ---------------- Set / order management ---------------- */
function currentSetFromControls(){
  const v = $('rangeSelect').value;
  if(v === 'all') return QUESTIONS.map((_,i)=>i);
  const [s,e] = v.split('-').map(Number);
  const arr = [];
  for(let i=s;i<e;i++) arr.push(i);
  return arr;
}
function shuffle(a){
  const r = a.slice();
  for(let i=r.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [r[i],r[j]]=[r[j],r[i]]; }
  return r;
}
function rebuild(keepPos){
  setIndices = currentSetFromControls();
  order = $('shuffleChk').checked ? shuffle(setIndices) : setIndices.slice();
  pos = keepPos ? Math.min(pos, order.length-1) : 0;
  hideSummary();
  render();
  updateStats();
}

/* ---------------- Rendering ---------------- */
function render(){
  if(order.length === 0) return;
  const gi = order[pos];
  const q = QUESTIONS[gi];
  const st = answers[gi];

  $('qcard').style.display = '';
  $('summary').classList.remove('show');

  $('qIndex').textContent = 'Câu ' + String(q.id).padStart(3,'0');
  $('qTag').textContent = `${pos+1} / ${order.length} trong bộ`;
  $('qText').textContent = q.question;

  // hint / reveal state
  const elim = answers[gi+'_elim'] || [];
  const correctIdx = q.options.findIndex(o => o.correct);
  const wrongLeft = q.options.filter((o,i)=>!o.correct && !elim.includes(i)).length;
  const revealedByHint = !st && elim.length>0 && wrongLeft===0; // every wrong option eliminated
  const revealed = !!st || revealedByHint;

  const ul = $('options');
  ul.innerHTML = '';
  q.options.forEach((o, i) => {
    const li = document.createElement('button');
    li.className = 'opt';
    li.setAttribute('data-i', i);
    li.innerHTML = `<span class="chip">${LETTERS[i]}</span><span class="txt"></span><span class="mark"></span>`;
    li.querySelector('.txt').textContent = o.text;
    const mark = li.querySelector('.mark');
    if(st){
      li.classList.add('locked');
      if(o.correct){ li.classList.add('correct'); mark.textContent='✓'; }
      if(st.selected === i && !o.correct){ li.classList.add('wrong'); mark.textContent='✗'; }
    } else if(revealedByHint){
      li.classList.add('locked');
      if(o.correct){ li.classList.add('hinted'); mark.textContent='💡'; }
      else { li.classList.add('eliminated'); }
    } else if(elim.includes(i)){
      li.classList.add('eliminated','locked');
    } else {
      li.addEventListener('click', () => choose(gi, i));
    }
    ul.appendChild(li);
  });

  // verdict
  const v = $('verdict');
  v.className = 'verdict';
  if(st){
    if(st.correct){ v.classList.add('show','good'); v.textContent='✓ Chính xác!'; }
    else{
      v.classList.add('show','bad'); v.textContent = `✗ Chưa đúng — đáp án đúng là ${LETTERS[correctIdx]}.`;
    }
  } else if(revealedByHint){
    v.classList.add('show','good'); v.textContent = `💡 Gợi ý: đáp án đúng là ${LETTERS[correctIdx]}.`;
  }

  // hint button — escalating: cue first, then eliminate wrong options, then reveal
  const cueShown = !!answers[gi+'_cue'];
  const hintBtn = $('hintBtn');
  if(!cueShown){
    hintBtn.disabled = false;
    hintBtn.textContent = '💡 Gợi ý gợi nhớ';
  } else if(st){
    hintBtn.disabled = true;
    hintBtn.textContent = '💡 Đã xem gợi ý';
  } else if(revealedByHint){
    hintBtn.disabled = true;
    hintBtn.textContent = '💡 Đã hiện đáp án';
  } else if(wrongLeft <= 1){
    hintBtn.disabled = false;
    hintBtn.textContent = '💡 Hiện đáp án';
  } else {
    hintBtn.disabled = false;
    hintBtn.textContent = '💡 Loại bớt đáp án';
  }

  // cue box (built-in memory cue, offline)
  const cueBox = $('cueBox');
  cueBox.className = 'cuebox';
  cueBox.innerHTML = '';
  if(cueShown){
    cueBox.classList.add('show');
    const cues = buildCue(gi);
    let inner = `<div class="cue-head">💡 Mẹo ghi nhớ</div>`;
    if(cues.length){
      inner += '<ul>' + cues.map(c=>`<li>${escapeHtml(c)}</li>`).join('') + '</ul>';
    } else {
      inner += `<div class="cue-empty">Câu này chưa có mẹo ghi nhớ riêng. Bấm “Loại bớt đáp án” để thu hẹp lựa chọn, hoặc “Giải thích (AI)” khi online để hiểu sâu hơn.</div>`;
    }
    cueBox.innerHTML = inner;
  }

  // explanation: shown once the answer is revealed (by answering or by hint)
  const exBtn = $('explainBtn');
  exBtn.hidden = !revealed;
  exBtn.disabled = false;
  exBtn.textContent = explanations[gi] ? '💡 Xem giải thích' : '💡 Giải thích (AI)';

  const exBox = $('explainBox');
  exBox.className = 'explain';
  exBox.innerHTML = '';
  if(revealed && explanations[gi]){
    exBox.classList.add('show');
    exBox.innerHTML = `<div class="ex-head">Giải thích</div>`;
    const p = document.createElement('div'); p.textContent = explanations[gi]; exBox.appendChild(p);
  }

  // nav buttons
  $('prevBtn').disabled = pos === 0;
  $('nextBtn').textContent = pos === order.length-1 ? 'Kết quả →' : 'Câu sau →';
  $('jumpInput').max = QUESTIONS.length;

  // animate
  const card = $('qcard');
  card.classList.remove('qchange'); void card.offsetWidth; card.classList.add('qchange');
}

function choose(gi, i){
  if(answers[gi]) return;
  const q = QUESTIONS[gi];
  const correct = !!q.options[i].correct;
  answers[gi] = { selected:i, correct };
  persist();
  render();
  updateStats();
}

// Built-in memory cue from the parasitology keyword glossary (offline, no API).
function buildCue(gi){
  const q = QUESTIONS[gi];
  const correct = (q.options.find(o=>o.correct)||{}).text || '';
  const hay = (q.question + ' ' + correct).toLowerCase();
  const got = [];
  for(const pair of CUE_DICT){
    const k = pair[0].toLowerCase();
    if(hay.indexOf(k) !== -1 && got.indexOf(pair[1]) === -1) got.push(pair[1]);
    if(got.length >= 3) break;
  }
  return got;
}

// Escalating offline help: 1) show memory cue, 2..) eliminate wrong options, last) reveal answer.
function useHint(){
  if(order.length===0) return;
  const gi = order[pos];
  const q = QUESTIONS[gi];
  // step 1: reveal the memory cue (always available, even after answering)
  if(!answers[gi+'_cue']){ answers[gi+'_cue'] = true; render(); return; }
  if(answers[gi]) return;                 // answered: cue already shown, no elimination
  const elim = answers[gi+'_elim'] || [];
  const wrong = q.options.map((o,idx)=>idx).filter(idx=>!q.options[idx].correct && !elim.includes(idx));
  if(wrong.length===0) return;            // all wrong already removed
  answers[gi+'_elim'] = elim.concat([shuffle(wrong)[0]]);
  render();
}

/* ---------------- AI explanation ---------------- */
function buildPrompt(q){
  const correctIdx = q.options.findIndex(o=>o.correct);
  const optText = q.options.map((o,i)=>`${LETTERS[i]}. ${o.text}`).join('\n');
  return `Câu hỏi: ${q.question}
Các lựa chọn:
${optText}
Đáp án đúng (theo tài liệu): ${LETTERS[correctIdx]}. ${q.options[correctIdx].text}

Hãy giải thích ngắn gọn (2–4 câu) bằng tiếng Việt vì sao đáp án này đúng, và nếu cần thì vì sao các đáp án khác sai. Viết rõ ràng, chính xác về mặt y học cho sinh viên ngành y. Không lặp lại đề bài.`;
}

async function fetchExplanation(q){
  if(!geminiKey) throw new Error('NO_KEY');
  const model = (geminiModel || 'gemini-2.0-flash').trim();
  const url = `https://generativelanguage.googleapis.com/v1beta/models/${encodeURIComponent(model)}:generateContent?key=${encodeURIComponent(geminiKey)}`;
  const prompt = "Bạn là giảng viên ký sinh trùng y học. Giải thích đáp án trắc nghiệm bằng tiếng Việt, ngắn gọn và chính xác.\n\n" + buildPrompt(q);
  const resp = await fetch(url, {
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body: JSON.stringify({
      contents:[{ parts:[{ text: prompt }] }],
      generationConfig:{ temperature:0.3, maxOutputTokens:1024 }
    })
  });
  if(!resp.ok){
    let msg = 'Lỗi HTTP ' + resp.status;
    try{ const e = await resp.json(); if(e && e.error && e.error.message) msg = e.error.message; }catch(_){}
    throw new Error(msg);
  }
  const data = await resp.json();
  const cand = data.candidates && data.candidates[0];
  const parts = (cand && cand.content && cand.content.parts) || [];
  const text = parts.map(p=>p.text||'').join('').trim();
  if(!text){
    if(cand && cand.finishReason && cand.finishReason !== 'STOP') throw new Error('Bị chặn: ' + cand.finishReason);
    throw new Error('empty');
  }
  return text;
}

function needKeyMessage(){
  $('settingsPanel').hidden = false;
  $('settingsBtn').scrollIntoView({block:'nearest'});
}

// Explain the current question (uses cache if present).
async function explain(){
  if(order.length===0) return;
  const gi = order[pos];
  if(!answers[gi] && !(answers[gi+'_elim'] && QUESTIONS[gi].options.filter((o,i)=>!o.correct && !answers[gi+'_elim'].includes(i)).length===0)) return;
  if(explanations[gi]){ render(); return; }
  const exBox = $('explainBox');
  exBox.classList.add('show');
  if(!geminiKey){
    exBox.innerHTML = `<div class="ex-head">Cần Gemini API key</div><div style="color:var(--muted)">Mở <b>⚙️ Gemini</b> ở góc trên, dán API key (miễn phí từ Google AI Studio) rồi bấm Lưu. Sau đó bấm lại “Giải thích (AI)”.</div>`;
    needKeyMessage();
    return;
  }
  exBox.innerHTML = `<div class="ex-head">Giải thích</div><div class="loading"><span class="spinner"></span> Đang hỏi Gemini…</div>`;
  $('explainBtn').disabled = true;
  try{
    explanations[gi] = await fetchExplanation(QUESTIONS[gi]);
    persist();
    render();
  }catch(err){
    exBox.innerHTML = `<div class="ex-head">Không tạo được giải thích</div><div style="color:var(--muted)">${escapeHtml(err.message)}.<br>Kiểm tra lại API key/model trong <b>⚙️ Gemini</b>, và mở trang bằng trình duyệt (không xem trong ứng dụng Zalo). Đáp án đúng vẫn được tô ở trên.</div>`;
    $('explainBtn').disabled = false;
  }
}

// Pre-generate explanations for every question in the current set.
async function explainAll(){
  if(batchRunning || order.length===0) return;
  const prog = $('batchProg');
  prog.hidden = false;
  if(!geminiKey){
    prog.innerHTML = `Cần nhập Gemini API key ở <b>⚙️ Gemini</b> trước.`;
    needKeyMessage();
    return;
  }
  const todo = setIndices.filter(gi => !explanations[gi]);
  if(todo.length===0){ prog.textContent = `Đã có giải thích cho cả ${setIndices.length} câu trong bộ này.`; return; }
  batchRunning = true;
  $('explainAllBtn').disabled = true;
  let done = 0, failed = 0, lastErr = '';
  const total = todo.length;
  const draw = () => { prog.innerHTML = `<span class="spinner"></span> Đang tạo giải thích bằng Gemini… <b>${done}/${total}</b>${failed?` · lỗi ${failed}`:''}`; };
  draw();
  const CONC = 5; let idx = 0;
  async function worker(){
    while(idx < todo.length){
      const gi = todo[idx++];
      try{ explanations[gi] = await fetchExplanation(QUESTIONS[gi]); }
      catch(e){ failed++; lastErr = e.message; }
      done++; draw();
      if(order[pos]===gi) render();
      if(done >= 6 && failed === done){ idx = todo.length; } // nothing succeeded -> stop early
    }
  }
  await Promise.all(Array.from({length:Math.min(CONC, todo.length)}, worker));
  batchRunning = false;
  $('explainAllBtn').disabled = false;
  persist();
  if(done-failed===0){
    prog.innerHTML = `Không tạo được giải thích. ${escapeHtml(lastErr)} — kiểm tra API key/model và mở trang bằng trình duyệt.`;
  } else {
    prog.innerHTML = `Đã tạo <b>${done-failed}/${total}</b> giải thích cho bộ này${failed?` (còn ${failed} câu lỗi, bấm lại để thử tiếp)`:''}.`;
  }
  render();
}

/* ---------------- Stats & summary ---------------- */
function updateStats(){
  const answered = setIndices.filter(gi=>answers[gi]);
  const done = answered.length;
  const ok = answered.filter(gi=>answers[gi].correct).length;
  const no = done - ok;
  const acc = done ? Math.round(ok/done*100) : 0;

  $('counterLabel').textContent = `Câu ${pos+1} / ${order.length}`;
  $('doneLabel').textContent = done;
  $('okLabel').textContent = ok;
  $('noLabel').textContent = no;
  $('accLabel').textContent = acc + '%';
  $('progFill').style.width = (order.length ? (done/setIndices.length*100) : 0) + '%';

  const wrongCount = no;
  const rw = $('reviewWrongBtn');
  rw.textContent = `Ôn câu sai (${wrongCount})`;
  rw.disabled = wrongCount === 0;
}

function showSummary(){
  const answered = setIndices.filter(gi=>answers[gi]);
  const ok = answered.filter(gi=>answers[gi].correct).length;
  const total = setIndices.length;
  const done = answered.length;
  const pct = done ? Math.round(ok/done*100) : 0;
  $('sumPct').textContent = pct;
  $('sumOk').textContent = ok;
  $('sumNo').textContent = done - ok;
  $('sumTotal').textContent = `${done}/${total}`;
  $('qcard').style.display = 'none';
  $('summary').classList.add('show');
}
function hideSummary(){
  $('summary').classList.remove('show');
  $('qcard').style.display = '';
}

/* ---------------- Review wrong ---------------- */
function reviewWrong(){
  const wrong = setIndices.filter(gi=>answers[gi] && !answers[gi].correct);
  if(wrong.length===0) return;
  // reset their answer state so user can retry
  wrong.forEach(gi=>{ delete answers[gi]; delete answers[gi+'_elim']; });
  setIndices = wrong;
  order = $('shuffleChk').checked ? shuffle(setIndices) : setIndices.slice();
  pos = 0;
  hideSummary();
  render();
  updateStats();
}

/* ---------------- Navigation ---------------- */
function go(delta){
  const next = pos + delta;
  if(next < 0) return;
  if(next >= order.length){ showSummary(); return; }
  pos = next; render(); updateStats();
}
function jumpTo(n){
  const target = n - 1;
  // find position of question with id n within current order; else within full set
  const giTarget = QUESTIONS.findIndex(q=>q.id === n);
  if(giTarget < 0) return;
  let p = order.indexOf(giTarget);
  if(p < 0){
    // switch to "all", keep shuffle off for predictable jump
    $('rangeSelect').value = 'all';
    setIndices = currentSetFromControls();
    order = $('shuffleChk').checked ? shuffle(setIndices) : setIndices.slice();
    p = order.indexOf(giTarget);
  }
  if(p >= 0){ pos = p; hideSummary(); render(); updateStats(); }
}

/* ---------------- Theme ---------------- */
function toggleTheme(){
  const cur = document.documentElement.getAttribute('data-theme');
  const next = cur === 'dark' ? '' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  $('themeBtn').textContent = next === 'dark' ? '☀️ Sáng' : '🌙 Tối';
  LS.set('kst_theme', next || 'light');
}

/* ---------------- Events ---------------- */
$('rangeSelect').addEventListener('change', ()=>rebuild(false));
$('shuffleChk').addEventListener('change', ()=>rebuild(false));
$('reviewWrongBtn').addEventListener('click', reviewWrong);
$('resetBtn').addEventListener('click', ()=>{
  for(const k in answers) delete answers[k];
  persist();
  rebuild(false);
});
$('hintBtn').addEventListener('click', useHint);
$('explainBtn').addEventListener('click', explain);
$('explainAllBtn').addEventListener('click', explainAll);
$('prevBtn').addEventListener('click', ()=>go(-1));
$('nextBtn').addEventListener('click', ()=>go(1));
$('randBtn').addEventListener('click', ()=>{ if(order.length){ pos = Math.floor(Math.random()*order.length); render(); updateStats(); }});
$('jumpBtn').addEventListener('click', ()=>{ const n=parseInt($('jumpInput').value,10); if(n) jumpTo(n); });
$('jumpInput').addEventListener('keydown', e=>{ if(e.key==='Enter'){ const n=parseInt(e.target.value,10); if(n) jumpTo(n);} });
$('themeBtn').addEventListener('click', toggleTheme);
$('sumReviewWrong').addEventListener('click', reviewWrong);
$('sumRestart').addEventListener('click', ()=>{ setIndices.forEach(gi=>{delete answers[gi]; delete answers[gi+'_elim'];}); persist(); rebuild(false); });

/* ---------------- Gemini settings ---------------- */
$('settingsBtn').addEventListener('click', ()=>{ const p=$('settingsPanel'); p.hidden = !p.hidden; });
$('keyEye').addEventListener('click', ()=>{ const i=$('keyInput'); i.type = i.type==='password' ? 'text' : 'password'; });
$('saveKeyBtn').addEventListener('click', ()=>{
  geminiKey = $('keyInput').value.trim();
  geminiModel = $('modelInput').value.trim() || 'gemini-2.0-flash';
  $('modelInput').value = geminiModel;
  LS.set('kst_gemini_key', geminiKey);
  LS.set('kst_gemini_model', geminiModel);
  const note = $('settingsNote');
  note.classList.add('ok');
  note.textContent = geminiKey ? '✓ Đã lưu trên thiết bị này. Giờ bạn có thể bấm “Giải thích (AI)” hoặc “Tạo giải thích cho cả bộ”.' : 'Đã xoá key khỏi thiết bị này.';
});

document.addEventListener('keydown', e=>{
  const tag = (e.target.tagName||'').toLowerCase();
  if(tag==='input' || tag==='select' || tag==='textarea') return;
  const k = e.key.toLowerCase();
  if(['a','b','c','d'].includes(k)){
    const i = LETTERS.indexOf(k.toUpperCase());
    const gi = order[pos];
    if(gi!==undefined && !answers[gi]){
      const el = $('options').querySelector(`[data-i="${i}"]`);
      if(el && !el.classList.contains('eliminated') && !el.classList.contains('locked')) choose(gi, i);
    }
  } else if(['1','2','3','4'].includes(k)){
    const i = parseInt(k,10)-1;
    const gi = order[pos];
    if(gi!==undefined && !answers[gi]){
      const el = $('options').querySelector(`[data-i="${i}"]`);
      if(el && !el.classList.contains('eliminated') && !el.classList.contains('locked')) choose(gi, i);
    }
  } else if(e.key==='ArrowRight'){ go(1); }
  else if(e.key==='ArrowLeft'){ go(-1); }
  else if(k==='h'){ useHint(); }
  else if(k==='e'){
    const gi=order[pos];
    if(gi===undefined) return;
    const q=QUESTIONS[gi], elim=answers[gi+'_elim']||[];
    const revealed = !!answers[gi] || (elim.length>0 && q.options.filter((o,i)=>!o.correct && !elim.includes(i)).length===0);
    if(revealed) explain();
  }
});

/* ---------------- Init ---------------- */
loadPersisted();
$('keyInput').value = geminiKey;
$('modelInput').value = geminiModel;
if(LS.get('kst_theme') === 'dark'){
  document.documentElement.setAttribute('data-theme', 'dark');
  $('themeBtn').textContent = '☀️ Sáng';
}
buildRanges();
rebuild(false);
updateStats();
</script>
